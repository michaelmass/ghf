{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": false,
  "singleQuote": true,
  "trailingComma": "all",
  "arrowParens": "avoid",
  "bracketSpacing": true,
  "useTabs": false,
  "tabWidth": 2,
  "printWidth": 320,
  "endOfLine": "lf",
  "insertFinalNewline": true,
  "ignorePatterns": ["dist", "node_modules", ".mcp.json", "opencode.json", "mcporter.json"]
}
